@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam handwritten false

skinparam actor {
    BackgroundColor #1A1A1A
    BorderColor #1A1A1A
    FontSize 12
    FontName Arial
}

skinparam usecase {
    BackgroundColor #FFFFFF
    BorderColor #1A1A1A
    ArrowColor #1A1A1A
    FontSize 12
}

actor "HSE Admin\n(Superviseur)" as admin
actor "Operator\n(Opérateur Labo)" as operator
actor "Auditor\n(Consultation)" as auditor

rectangle "Système de Surveillance Environnementale (Safi)" {
    
    '--- Cartographie ---
    usecase "UC1: Gérer la cartographie PostGIS\n(Ajouter/Modifier une cheminée)" as UC1
    
    '--- Ingestion des Flux ---
    usecase "UC2: Saisir une mesure manuellement" as UC2
    usecase "UC3: Importer un fichier CSV (Bulk)" as UC3
    
    '--- Contrôle Automatique ---
    usecase "UC4: Vérifier automatiquement les seuils\n(Dépassement de limite)" as UC4
    usecase "UC5: Déclencher une alerte PENDING" as UC5
    
    '--- Gestion des Alertes ---
    usecase "UC6: Suivre et modifier le statut des alertes\n(Mark Ongoing / Resolve)" as UC6
    
    '--- Consultation & Audit ---
    usecase "UC7: Consulter la carte interactive Leaflet" as UC7
    usecase "UC8: Visualiser le tableau de bord (KPIs)" as UC8
}

'--- Relations Héritage / Droits (Optionnel mais propre) ---
' L'admin et l'opérateur ont aussi les droits de consultation d'office
operator --|> auditor
admin --|> operator

'--- Connexions Acteurs -> Use Cases ---
admin --> UC1
admin --> UC6

operator --> UC2
operator --> UC3

auditor --> UC7
auditor --> UC8

'--- Relations Système / Extensions ---
UC2 ..> UC4 : <<include>>
UC3 ..> UC4 : <<include>>
UC4 ..> UC5 : <<extend>> : Si valeur > seuil

@endum